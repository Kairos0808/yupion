# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# runtime data lives in repo (Vercel read-only FS, published via git push)

# 安全: 绝不发布含个人隐私的文件。drafts(旧中文草稿含个人持仓/净值)禁止进仓库
/drafts/
*.draft.md
finfetch_cache/

# typescript
*.tsbuildinfo
next-env.d.ts
